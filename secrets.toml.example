# Template for Streamlit Community Cloud secrets.
# DO NOT commit a filled-in version. On Streamlit Cloud, paste these into
# the app's Settings -> Secrets box (not into the repo).
# Locally you can instead keep using your .env file.

APP_PASSWORD = "choose-a-strong-password"

PGHOST = "18.190.15.34"
PGPORT = "5432"
PGDATABASE = "your_database"
PGUSER = "your_user"
PGPASSWORD = "your_db_password"
PGSSLMODE = "require"

# Optional: enable the plain-English tab
# OPENAI_API_KEY = "sk-..."
# OPENAI_MODEL = "gpt-4o-mini"
